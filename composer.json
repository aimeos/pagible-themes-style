{
    "name": "aimeos/pagible-themes-style",
    "description": "Pagible CMS - Style theme with fashion-commerce editorial design",
    "keywords": ["laravel", "cms", "theme", "style", "fashion", "commerce", "editorial"],
    "homepage": "https://pagible.com",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "aimeos/pagible-theme": "*@dev"
    },
    "autoload": {
        "psr-4": {
            "Aimeos\\Cms\\": "src/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Aimeos\\Cms\\StyleServiceProvider"
            ]
        }
    }
}
